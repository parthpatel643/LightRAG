###############################################################################
# LightRAG Production Environment Configuration Template
# 
# AWS-Optimized Settings for 50+ Concurrent Users
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values (marked with YOUR_*, ACCOUNT_ID, etc.)
# 3. Review and adjust settings based on your specific requirements
# 4. Never commit .env file to version control
###############################################################################

###########################
### Server Configuration
###########################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='LightRAG Production - Aviation Contracts RAG'
WEBUI_DESCRIPTION="Production LightRAG deployment with AWS Neptune, DocumentDB, and Milvus"
LIGHTRAG_DATE_PREFACE=true

# Gunicorn workers (2-4 × CPU cores recommended)
WORKERS=4

# Worker timeout (should be > LLM_TIMEOUT)
TIMEOUT=180

# CORS origins (comma-separated, no spaces)
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

### SSL Configuration (recommended for production)
SSL=true
SSL_CERTFILE=/etc/ssl/certs/lightrag.crt
SSL_KEYFILE=/etc/ssl/private/lightrag.key

### Directory Configuration
INPUT_DIR=/data/inputs
WORKING_DIR=/data/rag_storage

### Tiktoken cache directory (for offline deployment)
TIKTOKEN_CACHE_DIR=/data/tiktoken

### Max nodes for graph retrieval
MAX_GRAPH_NODES=2000

### Logging Configuration
LOG_LEVEL=INFO
VERBOSE=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_DIR=/var/log/lightrag

# Structured logging for CloudWatch
LOG_FORMAT=json
LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_REQUEST_ID=true
LOG_INCLUDE_USER_ID=true

#####################################
### Authentication & Security
#####################################

# User accounts (format: username:password,username:password)
AUTH_ACCOUNTS='admin:CHANGE_THIS_PASSWORD,api_user:CHANGE_THIS_PASSWORD'

# JWT token configuration
TOKEN_SECRET=CHANGE_THIS_TO_RANDOM_256_BIT_SECRET
TOKEN_EXPIRE_HOURS=48
GUEST_TOKEN_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

# Token auto-renewal (sliding window expiration)
TOKEN_AUTO_RENEW=true
TOKEN_RENEW_THRESHOLD=0.5

# API key authentication
LIGHTRAG_API_KEY=CHANGE_THIS_TO_SECURE_API_KEY
WHITELIST_PATHS=/health,/metrics

# Token generation endpoint (if using external service)
# TOKEN_BINDING_HOST=https://your-token-service.com/generatetoken
# TOKEN_BINDING_API_KEY=YOUR_TOKEN_API_KEY

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=50
RATE_LIMIT_BURST=10
RATE_LIMIT_STORAGE=redis

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DESTINATION=cloudwatch
AUDIT_LOG_INCLUDE_REQUEST_BODY=false

######################################################################################
### Query Configuration (Production-Optimized)
###
### Context length control:
###    MAX_ENTITY_TOKENS + MAX_RELATION_TOKENS < MAX_TOTAL_TOKENS
###    Chunk_Tokens = MAX_TOTAL_TOKENS - Actual_Entity_Tokens - Actual_Relation_Tokens
######################################################################################

# LLM response cache (recommended for production)
ENABLE_LLM_CACHE=true
LLM_CACHE_TTL=3600
LLM_CACHE_MAX_SIZE=10000

# Query parameters
COSINE_THRESHOLD=0.35
TOP_K=15
CHUNK_TOP_K=20
MAX_ENTITY_TOKENS=2000
MAX_RELATION_TOKENS=2000
MAX_TOTAL_TOKENS=15000

# Chunk selection strategy (VECTOR or WEIGHT)
KG_CHUNK_PICK_METHOD=VECTOR

#########################################################
### Reranking Configuration (Production)
### RERANK_BINDING type: cohere, jina, aliyun
#########################################################
RERANK_BINDING=cohere
RERANK_BY_DEFAULT=true
MIN_RERANK_SCORE=0.35

# Cohere reranking (via proxy)
RERANK_MODEL=Cohere-Rerank-3.5
RERANK_BINDING_HOST=https://mars-llm-proxy-dev.ual.com/v1/unified/rerank
RERANK_BINDING_API_KEY=dummy_key

# Cohere chunking for token limits
RERANK_ENABLE_CHUNKING=true
RERANK_MAX_TOKENS_PER_DOC=480

########################################
### Document Processing Configuration
########################################
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=English

# PDF decryption (if needed)
# PDF_DECRYPT_PASSWORD=YOUR_PDF_PASSWORD

# Entity types for extraction
ENTITY_TYPES='["Airline", "Airport", "Flight", "Aircraft", "Route", "Gate", "Terminal", "Crew", "Passenger", "Schedule", "Regulation", "Weather", "Incident", "Maintenance", "Contract", "Service", "Price", "Date"]'

# Chunking configuration
CHUNK_SIZE=2000
CHUNK_OVERLAP_SIZE=200

# LLM summary configuration
FORCE_LLM_SUMMARY_ON_MERGE=8
SUMMARY_MAX_TOKENS=1200
SUMMARY_LENGTH_RECOMMENDED=600
SUMMARY_CONTEXT_SIZE=12000

# Source IDs management
MAX_SOURCE_IDS_PER_ENTITY=300
MAX_SOURCE_IDS_PER_RELATION=300
SOURCE_IDS_LIMIT_METHOD=FIFO
MAX_FILE_PATHS=100

# Related chunks per entity/relation
RELATED_CHUNK_NUMBER=3

###############################
### Concurrency Configuration
### PRODUCTION-OPTIMIZED FOR 50+ USERS
###############################

# LLM concurrency (4x increase from default)
MAX_ASYNC=16

# Parallel document processing (3x increase)
MAX_PARALLEL_INSERT=6

# Embedding concurrency (2.5x increase)
EMBEDDING_FUNC_MAX_ASYNC=20

# Embedding batch size (3x increase)
EMBEDDING_BATCH_NUM=32

###########################################################################
### LLM Configuration (Azure OpenAI via Proxy)
###########################################################################

# LLM timeout (reduced for production)
LLM_TIMEOUT=30

# LLM retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF=1.0
LLM_CIRCUIT_BREAKER_ENABLED=true
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60

# Azure OpenAI configuration
AZURE_OPENAI_API_VERSION=2025-04-01-preview
LLM_BINDING=azure_openai
LLM_BINDING_HOST=https://eur-sdr-int-pub.nestle.com/api/dv-exp-accelerator-openai-api/1/
LLM_BINDING_API_KEY=dummy_key
LLM_MODEL=gpt-4.1

# Failover endpoints (comma-separated)
# LLM_ENDPOINTS='["https://primary.com", "https://secondary.com"]'
# LLM_FAILOVER_ENABLED=true
# LLM_HEALTH_CHECK_INTERVAL=30

# OpenAI-compatible parameters
OPENAI_LLM_TEMPERATURE=0.15
OPENAI_LLM_MAX_TOKENS=9000

#######################################################################################
### Embedding Configuration (Azure OpenAI via Proxy)
#######################################################################################

# Embedding timeout
EMBEDDING_TIMEOUT=10

# Embedding retry configuration
EMBEDDING_MAX_RETRIES=3
EMBEDDING_CONNECTION_POOL_SIZE=20

# Azure OpenAI embedding
EMBEDDING_BINDING=azure_openai
EMBEDDING_BINDING_HOST=https://mars-llm-proxy-dev.ual.com/v2/unified
EMBEDDING_API_KEY=dummy_key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192

####################################################################
### Workspace Configuration
### Valid workspace name: a-z, A-Z, 0-9, and _
####################################################################
WORKSPACE=production

############################
### AWS Storage Configuration
### PRODUCTION-READY BACKENDS
############################

### Graph Storage: AWS Neptune
LIGHTRAG_GRAPH_STORAGE=NeptuneGraphStorage

### Vector Storage: Milvus
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

### KV & DocStatus Storage: AWS DocumentDB (MongoDB-compatible)
LIGHTRAG_KV_STORAGE=MongoKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=MongoDocStatusStorage

############################
### AWS Neptune Configuration
############################

# Neptune cluster endpoint (writer endpoint)
NEPTUNE_ENDPOINT=lightrag-neptune-cluster.cluster-XXXXX.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_REGION=us-east-1

# IAM authentication (recommended)
NEPTUNE_USE_IAM=true

# Connection pooling
NEPTUNE_MAX_CONNECTIONS=100
NEPTUNE_MIN_CONNECTIONS=10
NEPTUNE_CONNECTION_TIMEOUT=30
NEPTUNE_IDLE_TIMEOUT=300
NEPTUNE_MAX_CONNECTION_LIFETIME=3600

# Retry configuration
NEPTUNE_MAX_RETRIES=3
NEPTUNE_RETRY_BACKOFF=0.5
NEPTUNE_RETRY_BACKOFF_MAX=5.0
NEPTUNE_RETRY_JITTER=true

# Circuit breaker
NEPTUNE_CIRCUIT_BREAKER_ENABLED=true
NEPTUNE_CIRCUIT_BREAKER_THRESHOLD=5
NEPTUNE_CIRCUIT_BREAKER_TIMEOUT=60
NEPTUNE_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# Query optimization
NEPTUNE_QUERY_TIMEOUT=30
NEPTUNE_BATCH_SIZE=100
NEPTUNE_ENABLE_QUERY_CACHE=true
NEPTUNE_QUERY_CACHE_TTL=300

# OpenSearch integration
NEPTUNE_OPENSEARCH_ENDPOINT=https://search-lightrag-opensearch-XXXXX.us-east-1.es.amazonaws.com
NEPTUNE_OPENSEARCH_INDEX=lightrag-entities
NEPTUNE_OPENSEARCH_TIMEOUT=10
NEPTUNE_OPENSEARCH_MAX_RETRIES=3

# Monitoring
NEPTUNE_ENABLE_METRICS=true
NEPTUNE_METRICS_NAMESPACE=LightRAG/Neptune
NEPTUNE_ENABLE_SLOW_QUERY_LOG=true
NEPTUNE_SLOW_QUERY_THRESHOLD_MS=1000

############################
### AWS DocumentDB Configuration
### (MongoDB-compatible)
############################

# DocumentDB connection string
MONGO_URI=mongodb://admin:YOUR_PASSWORD@lightrag-docdb.cluster-XXXXX.us-east-1.docdb.amazonaws.com:27017/?tls=true&tlsCAFile=/etc/ssl/rds-combined-ca-bundle.pem&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
MONGO_DATABASE=LightRAG

# Connection pooling
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_IDLE_TIME_MS=30000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Retry configuration
MONGO_RETRY_WRITES=false
MONGO_RETRY_READS=true
MONGO_MAX_RETRIES=3
MONGO_RETRY_BACKOFF=0.5

# Circuit breaker
MONGO_CIRCUIT_BREAKER_ENABLED=true
MONGO_CIRCUIT_BREAKER_THRESHOLD=5
MONGO_CIRCUIT_BREAKER_TIMEOUT=60

# Monitoring
MONGO_ENABLE_METRICS=true
MONGO_METRICS_NAMESPACE=LightRAG/DocumentDB
MONGO_ENABLE_SLOW_QUERY_LOG=true
MONGO_SLOW_QUERY_THRESHOLD_MS=1000

############################
### Milvus Configuration
############################

# Milvus connection
MILVUS_URI=http://lightrag-milvus.us-east-1.elb.amazonaws.com:19530
MILVUS_DB_NAME=lightrag
MILVUS_USER=root
MILVUS_PASSWORD=YOUR_MILVUS_PASSWORD

# Connection pooling
MILVUS_MAX_CONNECTIONS=50
MILVUS_CONNECTION_TIMEOUT=30
MILVUS_RETRY_ATTEMPTS=3

# Index configuration (HNSW for production)
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

# HNSW parameters (optimized for 10k+ documents)
MILVUS_HNSW_M=32
MILVUS_HNSW_EF_CONSTRUCTION=512
MILVUS_HNSW_EF=256

# Search parameters
MILVUS_SEARCH_PARAMS='{"ef": 256}'

# Batch operations
MILVUS_BATCH_SIZE=100
MILVUS_INSERT_BUFFER_SIZE=1000

# Monitoring
MILVUS_ENABLE_METRICS=true
MILVUS_METRICS_NAMESPACE=LightRAG/Milvus
MILVUS_ENABLE_SLOW_QUERY_LOG=true
MILVUS_SLOW_QUERY_THRESHOLD_MS=100

###########################################################
### CloudWatch Monitoring Configuration
###########################################################

# CloudWatch integration
CLOUDWATCH_ENABLED=true
CLOUDWATCH_NAMESPACE=LightRAG/Production
CLOUDWATCH_LOG_GROUP=/aws/lightrag/api
CLOUDWATCH_METRICS_INTERVAL=60
CLOUDWATCH_REGION=us-east-1

# Custom metrics
ENABLE_QUERY_PROFILING=true
ENABLE_SLOW_QUERY_LOG=true
SLOW_QUERY_THRESHOLD_MS=1000

# Performance tracking
TRACK_QUERY_LATENCY=true
TRACK_LLM_LATENCY=true
TRACK_VECTOR_SEARCH_LATENCY=true
TRACK_GRAPH_QUERY_LATENCY=true

###########################################################
### AWS IAM Configuration
###########################################################

# IAM role for ECS tasks
AWS_IAM_ENABLED=true
AWS_IAM_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/LightRAG-ECS-Role

# AWS region
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Cognito authentication (optional)
# AWS_COGNITO_USER_POOL_ID=us-east-1_XXXXXXX
# AWS_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXX

###########################################################
### Redis Configuration (for caching and rate limiting)
###########################################################

# Redis connection
REDIS_URI=redis://lightrag-redis.XXXXX.cache.amazonaws.com:6379
REDIS_SOCKET_TIMEOUT=30
REDIS_CONNECT_TIMEOUT=10
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

# Redis for rate limiting
RATE_LIMIT_REDIS_URI=redis://lightrag-redis.XXXXX.cache.amazonaws.com:6379

############################
### Evaluation Configuration
############################

# RAGAS evaluation models
EVAL_LLM_MODEL=gpt-4o-mini
EVAL_LLM_BINDING_API_KEY=YOUR_EVAL_API_KEY
EVAL_LLM_BINDING_HOST=https://api.openai.com/v1

# Embedding for evaluation
EVAL_EMBEDDING_MODEL=text-embedding-3-large
EVAL_EMBEDDING_BINDING_API_KEY=YOUR_EVAL_API_KEY
EVAL_EMBEDDING_BINDING_HOST=https://api.openai.com/v1

# Performance tuning
EVAL_MAX_CONCURRENT=2
EVAL_QUERY_TOP_K=10
EVAL_LLM_MAX_RETRIES=5
EVAL_LLM_TIMEOUT=180

###########################################################
### Health Check Configuration
###########################################################

# Health check endpoints
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Component health checks
HEALTH_CHECK_NEPTUNE=true
HEALTH_CHECK_DOCUMENTDB=true
HEALTH_CHECK_MILVUS=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_LLM=true
HEALTH_CHECK_EMBEDDING=true

###########################################################
### Backup & Recovery Configuration
###########################################################

# Automated backups
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=s3://lightrag-backups-ACCOUNT_ID

# Point-in-time recovery
ENABLE_PITR=true
PITR_RETENTION_DAYS=7

###########################################################
### Feature Flags
###########################################################

# Experimental features
ENABLE_TEMPORAL_RAG=true
ENABLE_WORKSPACE_SWITCHING=true
ENABLE_ADVANCED_PROFILING=false
ENABLE_DISTRIBUTED_PROCESSING=false

###########################################################
### Performance Optimization
###########################################################

# Memory management
MAX_GRAPH_SIZE_MB=2048
MAX_VECTOR_CACHE_SIZE_MB=1024
MAX_LLM_CACHE_SIZE_MB=512

# Pagination
GRAPH_QUERY_PAGE_SIZE=1000
VECTOR_QUERY_PAGE_SIZE=100

# Garbage collection
ENABLE_AGGRESSIVE_GC=true
GC_THRESHOLD_MB=1024

###########################################################
### Development & Debug Settings
### (Disable in production)
###########################################################

# Debug mode (DISABLE IN PRODUCTION)
DEBUG=false
ENABLE_DEBUG_ENDPOINTS=false

# Profiling (enable only when needed)
ENABLE_PROFILING=false
PROFILING_OUTPUT_DIR=/tmp/profiling

###############################################################################
# END OF CONFIGURATION
###############################################################################

